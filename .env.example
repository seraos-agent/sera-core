# SERA-CORE Environment Configuration Example

# ── Server Runtime ──
# Use production in deployed environments. Development-only features (mock billing
# and the optional demo intent command) are automatically disabled in production.
NODE_ENV="development"
PORT="3001"
# Stable server-only session/state signing secret. Generate a high-entropy
# value for every deployed environment; never rotate it during an OAuth flow.
SESSION_SECRET="replace-with-a-long-random-server-secret"
# Comma-separated browser origins allowed to connect through Socket.io.
SERA_CORS_ORIGINS="http://localhost:5173"
# Production wallet logins require a signed, single-use Socket.io challenge.
# Set false to disable all development-only server features outside production too.
SERA_ENABLE_DEV_FEATURES="true"
# Optional: enables the named demo command only when dev features are enabled.
SERA_DEMO_INTENT_COMMAND="sera, evaluasi peluang baru"

# ── Supabase Identity & Durable User State ──
# Server-only. SUPABASE_SECRET_KEY must be stored in GCP Secret Manager in
# deployed environments and must never be exposed through VITE_* variables.
SUPABASE_URL="https://ovqkgjgixaddwnqnvhsn.supabase.co"
SUPABASE_SECRET_KEY="your-server-only-supabase-secret-key"

# ── Google Drive user-owned vault (optional until OAuth client is created) ──
# Uses Google Drive's limited drive.file scope. Core stores only an encrypted,
# revocable OAuth refresh token; validated memory stays in the user's SERA Vault
# folder in their own Google Drive.
# SERA_PUBLIC_URL="https://your-core-service.example.com"
# GOOGLE_DRIVE_CLIENT_ID="your-google-oauth-client-id"
# GOOGLE_DRIVE_CLIENT_SECRET="your-google-oauth-client-secret"
# Must be a unique, server-only 32-byte key (64 hex characters). Do not reuse
# a browser key or expose this through VITE_* variables.
# SERA_CLOUD_CREDENTIAL_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Memory ownership: local_development (development only), runtime_only
# (production default), or user_cloud (requires a configured user-cloud adapter).
# SERA never falls back to server disk when user_cloud is selected.
SERA_MEMORY_PERSISTENCE="runtime_only"

# ── LLM Configuration ──
QWEN_API="your-qwen-api-key-here"
# Optional: these defaults are used when unset. Keep the API key server-side.
QWEN_LIGHT_MODEL="qwen3.5-flash"
QWEN_HIGH_RISK_MODEL="qwen3.7-max"
# Optional OpenAI-compatible DashScope endpoint for the selected scope/region.
# QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions"

# ── MCP Integrations ──
# Required for web search capabilities via Brave MCP Server
BRAVE_API_KEY="your-brave-api-key-here"

# ── Agent Security (Phase 1) ──
# Master encryption key used by SecretManager to securely encrypt the Agentic Wallet's private key in the local database.
# Must be exactly 32 bytes (64 hex characters)
MASTER_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# ── Base Mainnet Configuration ──
BASE_RPC_URL="https://mainnet.base.org"

# ── Smart Contract Integration ──
# Address of the deployed SeraRegistry contract on Base Mainnet
SERA_REGISTRY_ADDRESS="0x..."

# ── JIT Auto-Funding (Gas Station) ──
# Private key of the Owner Wallet that will automatically supply ETH gas to the Agentic Wallet
OWNER_WALLET_PRIVATE_KEY="0x..."
