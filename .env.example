# SERA-CORE Environment Configuration Example

# Phase 8.1b / 8.2: Coinbase Developer Platform SDK v2
CDP_API_KEY_ID="organizations/..."
CDP_API_KEY_SECRET="-----BEGIN EC PRIVATE KEY-----\n..."
CDP_WALLET_SECRET="my_random_secret_string"

# Phase 8.2: Owner Identity & Smart Contracts
# Address of the human owner (e.g. your Smart Wallet or EOA)
OWNER_WALLET_ADDRESS="0xYourWalletAddressHere"

# Base Sepolia RPC URL (Optional, defaults to public endpoints if using viem without explicit transport config)
BASE_SEPOLIA_RPC_URL="https://sepolia.base.org"
